<h2 class="text-2xl font-semibold mb-6"><%= @product.new_record? ? t("admin.products.new") : t("admin.products.edit") %></h2>

<%= form_with model: [:admin, @product], local: true, html: { multipart: true } do |f| %>
  <!-- Title -->
  <div class="mb-4">
    <%= f.label :title, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :title, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" %>
  </div>

  <!-- Description -->
  <div class="mb-4">
    <%= f.label :description, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_area :description, rows: 4, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" %>
  </div>

  <!-- Quantity -->
  <div class="mb-4">
    <%= f.label :quantity, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.number_field :quantity, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" %>
  </div>

  <!-- Price -->
  <div class="mb-6">
    <%= f.label :price, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.number_field :price, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" %>
  </div>

  <!-- Image Upload + Preview -->
  <div class="mb-4">
    <%= f.label :image, t("admin.products.image"), class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.file_field :image, id: "product_image_input", class: "cursor-pointer px-3 py-2 border border-gray-300 rounded-lg bg-gray-100 hover:bg-gray-200" %>

    <div class="mt-2">
      <%# 預設顯示已上傳圖片或 no image %>
      <%= image_tag(
            @product.image.attached? ? url_for(@product.image.variant(resize_to_limit: [200,200])) : "no_image.jpeg",
            id: "product_image_preview",
            class: "border rounded w-40 h-40 object-cover"
          ) %>
    </div>
  </div>

  <!-- Submit -->
  <div>
    <%= f.submit @product.new_record? ? t("admin.products.create") : t("admin.products.update"),
        class: "px-4 py-2 bg-blue-500 text-white rounded-lg hover:bg-blue-600 transition",
        data: { disable_with: t("common.submitting") } %>
  </div>
<% end %>

<script>
  document.addEventListener("DOMContentLoaded", function() {
    const input = document.getElementById("product_image_input");
    const preview = document.getElementById("product_image_preview");

    input.addEventListener("change", function(event) {
      const file = event.target.files[0];
      if (!file) return;

      const reader = new FileReader();
      reader.onload = function(e) {
        preview.src = e.target.result;
      }
      reader.readAsDataURL(file);
    });
  });
</script>
