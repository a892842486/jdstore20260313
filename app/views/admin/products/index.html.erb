<div class="flex justify-between items-center p-4">
  <h1 class="text-2xl font-semibold">商品管理</h1>

  <%= link_to "＋ 新增商品",
      new_admin_product_path,
      class: "px-4 py-2 bg-green-500 text-white rounded-lg hover:bg-green-600 transition" %>
</div>
<div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-6 p-4">
  <% @products.each do |product| %>
    <div class="bg-white rounded-lg shadow hover:shadow-lg transition transform hover:-translate-y-1 hover:scale-105">
      <%= link_to product_path(product), class: "block" do %>
        <% if product.image.attached? %>
          <%= image_tag(
                url_for(product.image.variant(resize_to_limit: [300, 300])),
                class: "w-full h-48 object-cover rounded-t-lg"
              ) %>
        <% else %>
          <%= image_tag(
                asset_path("no_image.jpeg"),
                class: "w-full h-48 object-cover rounded-t-lg"
              ) %>
        <% end %>
      <% end %>

      <div class="p-4 text-center">
        <p class="font-semibold text-gray-800 truncate"><%= product.title %></p>
        <p class="text-blue-600 font-bold mt-1"><%= product.price %> 元</p>
        <%= link_to "編輯", edit_admin_product_path(product),
                    class: "mt-2 inline-block px-3 py-1 text-sm bg-blue-500 text-white rounded hover:bg-blue-600 transition" %>
      </div>
    </div>
  <% end %>
</div>
