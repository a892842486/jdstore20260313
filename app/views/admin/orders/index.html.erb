
<h2 class="text-2xl font-bold mb-6"><%= t("admin.orders.index_title") %></h2>

<div class="overflow-x-auto bg-white shadow rounded-2xl">
  <table class="min-w-full text-sm text-left text-gray-700">
    <thead class="bg-gray-100 text-gray-600 uppercase text-xs">
      <tr>
        <th class="px-6 py-3">#</th>
        <th class="px-6 py-3"><%= t("admin.orders.created_at") %></th>
        <th class="px-6 py-3"><%= t("admin.orders.customer") %></th>
        <th class="px-6 py-3"><%= t("admin.orders.status") %></th>
        <th class="px-6 py-3 text-right"><%= t("admin.orders.actions") %></th>
      </tr>
    </thead>

    <tbody class="divide-y">
      <% @orders.each do |order| %>
        <tr class="hover:bg-gray-50">
          <!-- ID -->
          <td class="px-6 py-4 font-medium text-blue-600">
            <%= link_to order.id, admin_order_path(order) %>
          </td>

          <!-- 時間 -->
          <td class="px-6 py-4">
            <%= l(order.created_at, format: :long) %>
          </td>

          <!-- 使用者 -->
          <td class="px-6 py-4">
            <%= order.user.email %>
          </td>

          <!-- 狀態 -->
          <td class="px-6 py-4">
            <span class="<%= order_state_badge(order) %>">
              <%= order.aasm_state.humanize %>
            </span>
          </td>

          <!-- 操作 -->
          <td class="px-6 py-4 text-right space-x-2">
            <% if order.may_ship? %>
              <%= button_to t("admin.orders.ship"),
                    ship_admin_order_path(order),
                    method: :post,
                    class: "btn-primary" %>
            <% end %>

            <% if order.may_deliver? %>
              <%= button_to t("admin.orders.deliver"),
                    shipped_admin_order_path(order),
                    method: :post,
                    class: "btn-success" %>
            <% end %>

            <% if order.may_cancel_order? %>
              <%= button_to t("admin.orders.cancel"),
                    cancel_admin_order_path(order),
                    method: :post,
                    data: { turbo_confirm: t("admin.orders.confirm_cancel") },
                    class: "btn-danger" %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
