<div class="mx-auto max-w-md px-4 py-12">
  <div class="rounded-2xl bg-white p-8 shadow-lg ring-1 ring-gray-200">
    <h2 class="mb-6 text-center text-2xl font-bold text-gray-900">Log in</h2>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-5" }) do |f| %>
      <div>
        <%= f.label :email, class: "mb-1 block text-sm font-medium text-gray-700" %>
        <%= f.email_field :email,
            autofocus: true,
            autocomplete: "email",
            class: "block w-full rounded-lg border border-gray-300 bg-white px-3 py-2 text-gray-900 shadow-sm focus:border-red-500 focus:outline-none focus:ring-2 focus:ring-red-500" %>
      </div>

      <div>
        <%= f.label :password, class: "mb-1 block text-sm font-medium text-gray-700" %>
        <%= f.password_field :password,
            autocomplete: "current-password",
            class: "block w-full rounded-lg border border-gray-300 bg-white px-3 py-2 text-gray-900 shadow-sm focus:border-red-500 focus:outline-none focus:ring-2 focus:ring-red-500" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="flex items-center gap-2">
          <%= f.check_box :remember_me, class: "h-4 w-4 rounded border-gray-300 text-red-600 focus:ring-red-500" %>
          <%= f.label :remember_me, class: "text-sm text-gray-700" %>
        </div>
      <% end %>

      <%= f.submit "Log in",
          class: "w-full rounded-lg bg-red-600 px-4 py-2 font-semibold text-white shadow-sm transition hover:bg-red-700 cursor-pointer" %>
    <% end %>

    <div class="mt-6 text-center text-sm text-gray-600">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
