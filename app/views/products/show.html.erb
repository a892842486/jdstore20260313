<div class="max-w-4xl mx-auto p-6 bg-white rounded-lg shadow">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <!-- 圖片 -->
    <div>
      <% if @product.image.attached? %>
        <%= image_tag url_for(@product.image.variant(resize_to_limit: [500, 500])),
                      class: "w-full h-96 object-cover rounded-lg" %>
      <% else %>
        <%= image_tag "no_image.jpeg",
                      class: "w-full h-96 object-cover rounded-lg" %>
      <% end %>
    </div>

    <!-- 資訊 -->
    <div class="flex flex-col justify-between">
      <div>
        <h2 class="text-2xl font-bold mb-4"><%= @product.title %></h2>
        <p class="text-gray-700 mb-4"><%= @product.description %></p>
        <p class="text-gray-900 font-semibold mb-2">數量: <%= @product.quantity %></p>
        <p class="text-blue-600 font-bold text-xl mb-4"><%= @product.price %> 元</p>
      </div>

      <div class="mt-4">
        <% if @product.quantity > 0 %>
          <%= button_to "加入購物車",
              add_to_cart_product_path(@product),
              method: :post,
              class: "px-6 py-3 bg-red-600 text-white rounded-lg hover:bg-red-700 transition" %>
        <% else %>
          <span class="text-gray-500 text-lg">已銷售一空，無法購買</span>
        <% end %>
      </div>
    </div>
  </div>
</div>
