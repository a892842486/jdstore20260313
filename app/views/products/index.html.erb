<!-- Hero Banner -->
<div class="relative mb-8 rounded-2xl overflow-hidden shadow-lg">

  <%= image_tag "banner.jpg",
      class: "w-full h-[320px] object-cover" %>

  <!-- Overlay -->
  <div class="absolute inset-0 bg-black/40 flex flex-col justify-center px-10">

    <h1 class="text-4xl font-bold text-white mb-3">
      <%= t("products.hero.title") %>
    </h1>

    <p class="text-lg text-gray-200 mb-2">
      <%= t("products.hero.subtitle") %>
    </p>

    <p class="text-sm text-gray-300">
      <%= t("products.hero.badge") %>
    </p>

  </div>
</div>

<!-- Product Grid -->
<div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-6 p-4">
  <% @products.each do |product| %>
    <div class="bg-white rounded-lg shadow hover:shadow-lg transition transform hover:-translate-y-1 hover:scale-105">
      <%= link_to product_path(product), class: "block" do %>
        <% if product.image.attached? %>
          <%= image_tag(
                url_for(product.image.variant(resize_to_limit: [300, 300])),
                class: "w-full h-48 object-cover rounded-t-lg"
              ) %>
        <% else %>
          <%= image_tag(
                asset_path("no_image.jpeg"),
                class: "w-full h-48 object-cover rounded-t-lg"
              ) %>
        <% end %>
      <% end %>

      <div class="p-4 text-center">
        <p class="font-semibold text-gray-800 truncate"><%= product.title %></p>
        <p class="text-blue-600 font-bold mt-1"><%= product.price %> <%= t("currency.unit") %></p>
      </div>
    </div>
  <% end %>
</div>
