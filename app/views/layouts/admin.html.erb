<!DOCTYPE html>
<html>
<head>
  <title>商品管理</title>
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>
</head>

<body class="bg-gray-100 text-gray-900 min-h-screen">
  <%= render "common/navbar" %>

  <div class="flex max-w-7xl mx-auto mt-6 px-4">
    <!-- Sidebar -->
    <aside class="w-64 bg-white rounded-lg shadow p-4 mr-6">
      <nav class="space-y-2">
        <%= link_to "Products", admin_products_path,
            class: "block px-3 py-2 rounded hover:bg-gray-100 transition" %>
        <!-- 可以再加其他 admin menu -->
      </nav>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 bg-white rounded-lg shadow p-6">
    <%= render "common/flashes" %>
      <%= yield %>
    </main>
  </div>

  <%= render "common/footer" %>
</body>
</html>
