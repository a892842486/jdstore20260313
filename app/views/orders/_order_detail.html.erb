<div class="max-w-4xl mx-auto px-4">

  <!-- 標題 -->
  <h2 class="text-2xl font-semibold mb-4"><%= t("orders.detail.title") %></h2>

  <!-- 商品快照 -->
  <div class="overflow-x-auto rounded-lg border border-gray-200">
    <table class="min-w-full text-sm text-gray-700">
      <thead class="bg-gray-50 text-gray-600">
        <tr>
          <th class="px-4 py-3 text-left"><%= t("orders.detail.product_name") %></th>
          <th class="px-4 py-3 text-left"><%= t("orders.detail.unit_price") %></th>
          <th class="px-4 py-3 text-left"><%= t("orders.detail.quantity") %></th>
          <th class="px-4 py-3 text-left"><%= t("orders.detail.subtotal") %></th>
        </tr>
      </thead>

      <tbody class="divide-y">
        <% order.product_lists.each do |pl| %>
          <tr class="hover:bg-gray-50">
            <td class="px-4 py-3"><%= pl.product_name %></td>

            <td class="px-4 py-3">
              <%= number_to_currency(pl.product_price, unit: t("currency.unit"), precision: 0, format: "%n%u") %>
            </td>

            <td class="px-4 py-3"><%= pl.quantity %></td>

            <td class="px-4 py-3 font-semibold">
              <%= number_to_currency(pl.product_price * pl.quantity, unit: t("currency.unit"), precision: 0, format: "%n%u") %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <!-- 總價 -->
  <div class="flex justify-end mt-4">
    <span class="text-lg font-semibold">
      <%= t("orders.detail.total") %> <%= number_to_currency(order.total, unit: t("currency.unit"), precision: 0, format: "%n%u") %>
    </span>
  </div>

  <hr class="my-6">

  <!-- 寄送資訊 -->
  <h2 class="text-2xl font-semibold mb-4"><%= t("orders.detail.shipping_info") %></h2>

  <div class="rounded-lg border border-gray-200 overflow-hidden">
    <table class="min-w-full text-sm">
      <tbody>

        <tr class="bg-gray-50">
          <td class="px-4 py-2 font-medium"><%= t("orders.detail.billing_user") %></td>
        </tr>
        <tr>
          <td class="px-4 py-2">
            <%= order.billing_name %> - <%= order.billing_address %>
          </td>
        </tr>

        <tr class="bg-gray-50">
          <td class="px-4 py-2 font-medium"><%= t("orders.detail.shipping_user") %></td>
        </tr>
        <tr>
          <td class="px-4 py-2">
            <%= order.shipping_name %> - <%= order.shipping_address %>
          </td>
        </tr>

      </tbody>
    </table>
  </div>

</div>
