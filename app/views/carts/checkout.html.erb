<div class="max-w-5xl mx-auto px-4 py-8">

  <!-- 購物明細 -->
  <h2 class="text-2xl font-semibold mb-6">購物明細</h2>

  <div class="overflow-hidden border rounded-lg">
    <table class="min-w-full text-sm text-left">
      <thead class="bg-gray-100 text-gray-700">
        <tr>
          <th class="px-4 py-3 w-2/3">商品明細</th>
          <th class="px-4 py-3">單價</th>
          <th class="px-4 py-3">數量</th>
        </tr>
      </thead>

      <tbody class="divide-y">
        <% current_cart.cart_items.each do |cart_item| %>
          <tr>
            <td class="px-4 py-3">
              <%= link_to cart_item.product.title,
                          product_path(cart_item.product),
                          class: "text-blue-600 hover:underline" %>
            </td>

            <td class="px-4 py-3">
              <%= cart_item.product.price %>
            </td>

            <td class="px-4 py-3">
              <%= cart_item.quantity %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <!-- 總價 -->
  <div class="flex justify-end mt-4 text-lg font-semibold">
    總計 <%= render_cart_total_price(current_cart) %> 元
  </div>

  <!-- 分隔線 -->
  <div class="border-t my-8"></div>

  <!-- 訂單資訊 -->
  <h2 class="text-2xl font-semibold mb-6">訂單資訊</h2>

  <div class="bg-white border rounded-lg p-6 shadow-sm">

    <%= simple_form_for @order, url: orders_path do |f| %>

      <!-- 訂購人 -->
      <h3 class="text-lg font-medium mb-4">訂購人</h3>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
        <div>
          <%= f.input :billing_name,
                      input_html: { class: "w-full border rounded px-3 py-2" },
                      label_html: { class: "block mb-1 font-medium" } %>
        </div>

        <div>
          <%= f.input :billing_address,
                      input_html: { class: "w-full border rounded px-3 py-2" },
                      label_html: { class: "block mb-1 font-medium" } %>
        </div>
      </div>

      <!-- 收貨人 -->
      <h3 class="text-lg font-medium mb-4">收貨人</h3>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
        <div>
          <%= f.input :shipping_name,
                      input_html: { class: "w-full border rounded px-3 py-2" },
                      label_html: { class: "block mb-1 font-medium" } %>
        </div>

        <div>
          <%= f.input :shipping_address,
                      input_html: { class: "w-full border rounded px-3 py-2" },
                      label_html: { class: "block mb-1 font-medium" } %>
        </div>
      </div>

      <!-- 送出 -->
      <div class="flex justify-end">
        <%= f.submit "生成訂單",
                     class: "bg-red-500 hover:bg-red-600 text-white px-6 py-2 rounded-lg font-medium transition" %>
      </div>

    <% end %>

  </div>

</div>
