<div class="container mx-auto px-4">
  <div class="w-full">
    <div class="flex justify-between items-center mb-4">
      <h2 class="text-2xl font-semibold">購物車</h2>

      <%= button_to "清空購物車",
          clean_carts_path,
          method: :delete,
          data: { confirm: "你確定要清空整個購物車嗎？" },
          class: "text-sm text-red-500 hover:text-red-700 underline transition" %>
    </div>

    <div class="overflow-x-auto">
      <table class="min-w-full border border-gray-300">
        <thead class="bg-gray-100">
          <tr>
            <th colspan="2" class="px-4 py-2 text-left border-b border-gray-300">商品資訊</th>
            <th class="px-4 py-2 text-left border-b border-gray-300">單價</th>
            <th class="px-4 py-2 text-left border-b border-gray-300">數量</th>
            <th class="px-4 py-2 border-b border-gray-300">操作</th>
          </tr>
        </thead>
        <tbody>
          <% @cart_items.each do |cart_item| %>
            <tr class="hover:bg-gray-50">
              <td class="px-4 py-2 border-b border-gray-300">
                <%= link_to product_path(cart_item.product) do %>
                  <% if cart_item.product.image.attached? %>
                    <%= image_tag(cart_item.product.image.variant(resize_to_limit: [100,100]),
                                  class: "w-24 h-24 object-cover rounded") %>
                  <% else %>
                    <%= image_tag("no_image.jpeg", class: "w-24 h-24 object-cover rounded") %>
                  <% end %>
                <% end %>
              </td>
              <td class="px-4 py-2 border-b border-gray-300">
                <%= link_to cart_item.product.title, product_path(cart_item.product),
                            class: "text-blue-600 hover:underline" %>
              </td>
              <td class="px-4 py-2 border-b border-gray-300">
                <%= number_to_currency(cart_item.product.price, unit: "元", format: "%n%u", precision: 0) %>
              </td>
              <td class="px-4 py-2 border-b border-gray-300">
                <%= form_with model: cart_item,
                    url: cart_item_path(cart_item),
                    method: :patch,
                    local: true,
                    class: "flex items-center gap-2" do |f| %>

                  <%= f.select :quantity,
                      1..cart_item.product.quantity,
                      {},
                      class: "border border-gray-300 rounded px-2 py-1" %>

                  <%= f.submit "更新",
                      class: "px-3 py-1 bg-blue-500 text-white rounded hover:bg-blue-600 text-sm" %>

                <% end %>
              </td>
              <td class="px-4 py-2 border-b border-gray-300">
                <%= button_to cart_item_path(cart_item),
                    method: :delete,
                    data: { confirm: "確定刪除這個商品嗎？" },
                    class: "text-red-500 hover:text-red-700 transition" do %>
                🗑️
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <div class="flex justify-end mt-4">
      <span class="text-lg font-semibold text-gray-800">
        總計 <%= number_to_currency(render_cart_total_price(current_cart), unit: "元", precision: 0, format: "%n%u") %>
      </span>
    </div>

    <hr class="my-6">

    <div class="flex justify-end">
      <%= link_to "確認結帳", "#", method: :post,
                  class: "px-6 py-3 bg-red-600 text-white rounded-lg text-lg hover:bg-red-700 transition" %>
    </div>
  </div>
</div>
