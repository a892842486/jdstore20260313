<h2 class="text-2xl font-bold mb-6">使用者訂單歷史</h2>

<div class="overflow-x-auto">
  <table class="min-w-full border border-gray-200 rounded-lg overflow-hidden">
    <thead class="bg-gray-100">
      <tr>
        <th class="px-4 py-2 text-left text-sm font-semibold text-gray-700">訂單編號</th>
        <th class="px-4 py-2 text-left text-sm font-semibold text-gray-700">生成時間</th>
      </tr>
    </thead>

    <tbody class="divide-y">
      <% @orders.each do |order| %>
        <tr class="hover:bg-gray-50 transition">
          <td class="px-4 py-2">
            <%= link_to order.id,
                account_order_path(order),
                class: "text-blue-600 hover:underline font-medium" %>
          </td>
          <td class="px-4 py-2 text-gray-600">
            <%= l(order.created_at, format: :long) %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
